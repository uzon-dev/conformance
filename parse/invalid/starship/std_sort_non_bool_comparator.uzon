// ERROR: §5.16.2 + §3.8
// std.sort comparator must return bool, not i32
_shared is struct "./shared"

modules are _shared.bridge, _shared.base_module

bad is std.sort(
    modules,
    function a as _shared.BaseModule, b as _shared.BaseModule returns i32 {
        a.power_kw to i32 - b.power_kw to i32
    }
)
