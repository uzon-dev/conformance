// ERROR: бї3.8 + бї6.3 + бї3.4
// separately called function types Б─■ same signature, different names
_shared is struct "./shared"

formatPower is function m as _shared.BaseModule returns string {
    "{m.power_kw}kW"
} called PowerFormatter

formatCrew is function m as _shared.BaseModule returns string {
    "crew: {m.capacity}"
} called CrewFormatter

// PowerFormatter Б┴═ CrewFormatter Б─■ nominal identity
bad is [ formatPower, formatCrew ] as [PowerFormatter]
