// §3.2 + §3.2.1 + §3.4.2 — Sparse-config pattern.
Rule is struct {
    title is null
    app_id is null
    tag is null
    output is null
    floating is null
    dimension is null
    is_terminal is null
}

rules is [
    { app_id is { str is "", match_null is true }, floating is true },
    { app_id is { str is "zenity" }, floating is true },
    { app_id is { str is "foot" }, is_terminal is true },
] as [Rule]
