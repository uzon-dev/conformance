// 禮8 + 禮5.3 + 禮5.8.2 + 禮5.4 + 禮5.9 + 禮5.6
// expression continuation across multiple operator types
values are 10, 20, 30, 40, 50

// arithmetic continuation
total is 100
      + 200
      + 300
      - 50

// concatenation continuation
message is "hello"
         ++ " "
         ++ "world"
         ++ "!"

// logical continuation
check is true
      and true
      and not false
      or false

// comparison in continued expression
bounded is total > 0
         and total < 1000

// if with continuation
result is if bounded
    then "in range: " ++ total to string
    else "out of range"
