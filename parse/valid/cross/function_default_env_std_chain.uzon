// бї3.8 + бї5.13 + бї5.7 + бї5.16.4 + бї5.16.2 + бї4.4.1
// function with default + env + or else + std.split + std.map + interpolation
formatPath is function raw as string,
    separator as string default ":" returns [string] {
    parts is std.split(raw, separator)
    std.map(parts, function p as string returns string { std.trim(p) })
}

unix_paths is formatPath(env.PATH or else "/usr/bin:/bin")
win_paths is formatPath(
    env.WIN_PATH or else "C:\\Users;C:\\Windows",
    ";"
)

unix_display is std.join(unix_paths, " Б├▓ ")
win_display is std.join(win_paths, " Б├▓ ")
report is "UNIX: {unix_display}"
          "WIN:  {win_display}"
