// §3.3 + §5.12: tuple access chains
coordinates are
    (10.0, 20.0),
    (30.0, 40.0),
    (50.0, 60.0)

// chained access: list → tuple → element
first_x is coordinates.first.0
second_y is coordinates.second.1
last is coordinates.third

// tuple in function
distance is function p as (f64, f64) returns f64 {
    (p.0 ^ 2.0 + p.1 ^ 2.0) ^ 0.5
}

d1 is distance(coordinates.first)
d2 is distance((3.0, 4.0))             // 5.0
