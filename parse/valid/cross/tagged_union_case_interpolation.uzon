// бї3.7 + бї5.10 + бї4.4.1: tagged union + case named + interpolation
response is "data loaded" named success from
    success as string, error as string, pending as null
    called ApiResult

display is case named response
    when success then "Б°⌠ {response}"
    when error then "Б°≈ {response}"
    when pending then "Б▐Ё waiting..."
    else "? unknown"

is_ok is response is named success
reuse is "timeout" as ApiResult named error
