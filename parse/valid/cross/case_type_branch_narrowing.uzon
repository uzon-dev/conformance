// §5.10: Branch narrowing — scrutinee narrowed to matched type, all branches same result type
u is 42 from union i32, f64, string

msg is case type u
    when i32 then (u + 1) to string       // u narrowed to i32
    when f64 then (u * 2.0) to string     // u narrowed to f64
    when string then u ++ "!"              // u narrowed to string — already string-ish
    else "other"
