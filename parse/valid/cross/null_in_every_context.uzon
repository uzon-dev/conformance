// §4.5: null compatibility across contexts
list_with_null is [ 1, null, 3 ]
struct_with_null is { name is "test", value is null }

// null in equality
eq is null is null                     // true
neq is null is not null                // false

// null in or else (passes through — not undefined)
pass is null or else "fallback"        // null

// null in with override
base is { x is 1 as i32, y is null }
overridden is base with { y is 42 as i32 }    // null → i32 OK
reset is overridden with { y is null }          // i32 → null OK

// null in case
check is case null
    when null then "is null"
    else "not null"

// null in tagged union variant
scan is null named empty from found as string, empty as null called ScanResult
