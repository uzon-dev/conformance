// French
fr_lo is "château"
fr_up is "RÉSUMÉ"
fr_lo2 is "garçon"
fr_up2 is "NAÏVE"
fr_lo3 is "noël"
fr_up3 is "CAFÉ"

// German — simple folding: `ß` has no one-to-one uppercase and is unchanged
de_lo is "ärger"
de_up is "STRAßE"
de_lo2 is "übung"
de_up2 is "MÜNCHEN"
de_lo3 is "öffnung"

// Roundtrip: upper then lower — `ß` stays `ß` through both passes
fr_round is "château"
de_round is "straße"

// Spanish, Danish, Polish
es_up is "SEÑOR"
da_lo is "ørsted"
pl_up is "ŁÓDŹ"

// Greek
gr_lo is "ωμέγα"
gr_up is "ΑΛΦΑ"
