csp is {
    'default-src' is [ "'self'" ]
    'script-src' is [ "'self'", "https://cdn.example.com", "'nonce-abc123'" ]
    'style-src' is [ "'self'", "'unsafe-inline'" ]
    'img-src' is [ "'self'", "data:", "https:" ]
    'font-src' is [ "'self'", "https://fonts.googleapis.com" ]
    'connect-src' is [ "'self'", "https://api.example.com", "wss://ws.example.com" ]
    'frame-ancestors' is [ "'none'" ]
    'base-uri' is [ "'self'" ]
    'form-action' is [ "'self'" ]
}
