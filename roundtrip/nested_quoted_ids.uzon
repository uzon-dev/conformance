headers is {
    'Content-Type' is "application/json"
    'Accept-Language' is "en-US,en;q=0.9"
    'Cache-Control' is "no-cache"
    nested is {
        'X-Forwarded-For' is "10.0.0.1"
        'X-Real-IP' is "192.168.1.1"
        deep is {
            'X-Custom-Header' is "value"
            'X-Another-One' is "another"
        }
    }
}
