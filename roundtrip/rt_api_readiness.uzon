endpoint is {
    name is "readiness"
    method is "GET"
    path is "/api/v1/readiness"
    auth_required is false
    rate_limit is 100 as u32
    timeout_ms is 5000 as u32
    cache_ttl_sec is 300 as u32
    request_body is false
    response_codes is [ 200 as u16, 400 as u16, 200 as u16, 500 as u16 ]
}
