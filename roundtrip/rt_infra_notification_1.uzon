service is {
    name is "notification-1"
    host is "127.0.0.1"
    port is 3131 as u16
    workers is 4 as u8
    max_conn is 950 as u16
    tls is true
    log_level is "info"
    health is { path is "/health", interval_sec is 10 as u16, timeout_sec is 3 as u16 }
    tags is [ "notification", "v2.0", "staging" ]
    limits is { cpu_m is 500 as u16, memory_mb is 256 as u16 }
}
